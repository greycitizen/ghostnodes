# ══════════════════════════════════════════════════════════════════════════════
# DETECÇÃO DE HARDWARE — salva em var/hardware.env
# ══════════════════════════════════════════════════════════════════════════════
detect_hardware() {
    section "🖥  Detecção de Hardware"
    echo ""

    # Arquitetura
    GN_HW_ARCH=$(uname -m 2>/dev/null || echo "unknown")
    # Normaliza
    case "$GN_HW_ARCH" in
        aarch64)       GN_HW_ARCH="arm64" ;;
        x86_64)        GN_HW_ARCH="x86_64" ;;
        armv7l|armhf)  GN_HW_ARCH="armhf" ;;
    esac

    # Modelo
    GN_HW_MODEL=$(cat /proc/device-tree/model 2>/dev/null | tr -d '\0' \
                  || cat /sys/firmware/devicetree/base/model 2>/dev/null | tr -d '\0' \
                  || grep -m1 "^model name" /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ *//' \
                  || echo "Generic $(uname -m)")

    # CPU cores
    GN_HW_CPU_CORES=$(nproc 2>/dev/null || grep -c "^processor" /proc/cpuinfo 2>/dev/null || echo "1")

    # RAM em GB (arredondado)
    local RAM_KB
    RAM_KB=$(awk '/^MemTotal/{print $2}' /proc/meminfo 2>/dev/null || echo "0")
    GN_HW_RAM_GB=$(( RAM_KB / 1024 / 1024 ))
    # Garante mínimo de 1 se maior que 512MB
    [ "$RAM_KB" -gt 524288 ] && [ "$GN_HW_RAM_GB" -eq 0 ] && GN_HW_RAM_GB=1

    # Disco em GB (maior partição ou disco raiz)
    local DISK_KB
    DISK_KB=$(df / 2>/dev/null | awk 'NR==2{print $2}' || echo "0")
    GN_HW_DISK_GB=$(( DISK_KB / 1024 / 1024 ))

    # Sistema operacional
    GN_HW_OS=$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo "Unknown")

    # Exibe
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s${RESET}\n" "Modelo:"      "$GN_HW_MODEL"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s${RESET}\n" "Arquitetura:" "$GN_HW_ARCH"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s cores${RESET}\n" "CPU:"   "$GN_HW_CPU_CORES"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s GB${RESET}\n" "RAM:"       "$GN_HW_RAM_GB"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s GB${RESET}\n" "Disco (/):" "$GN_HW_DISK_GB"
    printf "  ${DIM}%-20s${RESET} ${BOLD}%s${RESET}\n" "Sistema:"      "$GN_HW_OS"

    echo ""

    # Salva em var/hardware.env
    # Salva em /tmp primeiro; movido para GN_ROOT após instalação
    mkdir -p "$(dirname "$GN_HW_COMPAT_FILE")" 2>/dev/null || true
    cat > "$GN_HW_COMPAT_FILE" << HWENV
# hardware.env — gerado automaticamente em $(date '+%F %T')
GN_HW_ARCH="${GN_HW_ARCH}"
GN_HW_MODEL="${GN_HW_MODEL}"
GN_HW_CPU_CORES="${GN_HW_CPU_CORES}"
GN_HW_RAM_GB="${GN_HW_RAM_GB}"
GN_HW_DISK_GB="${GN_HW_DISK_GB}"
GN_HW_OS="${GN_HW_OS}"
HWENV
    step_ok "Hardware salvo em: $GN_HW_COMPAT_FILE"
}

# ══════════════════════════════════════════════════════════════════════════════
# COMPATIBILIDADE — verifica se o hw suporta um subprojeto
# Retorna: 0=ok, 1=ok com avisos, 2=incompatível
# Preenche: _COMPAT_MSG com mensagem ao usuário
# ══════════════════════════════════════════════════════════════════════════════
check_compat() {
    local PROJECT="$1"
    _COMPAT_MSG=""
    _COMPAT_WARNINGS=()
    _COMPAT_MODE=""   # ex: "pruned" para Satoshi
    local RC=0

    case "$PROJECT" in
        halfin)
            # Requer arm64, mín 512MB RAM
            if [ "$GN_HW_ARCH" != "arm64" ]; then
                _COMPAT_MSG="Halfin Node é otimizado para arm64 (OrangePi Zero 3). Arch atual: ${GN_HW_ARCH}."
                _COMPAT_WARNINGS+=("Hardware não é arm64 — funcionalidade limitada")
                RC=1
            fi
            if [ "$GN_HW_RAM_GB" -lt 1 ]; then
                _COMPAT_WARNINGS+=("RAM muito baixa (${GN_HW_RAM_GB}GB) — mínimo recomendado: 1GB")
                RC=1
            fi
            ;;

        satoshi)
            # Full node: 400GB+, 2GB+ RAM
            # Pruned node: 10GB+, 1GB+ RAM
            if [ "$GN_HW_RAM_GB" -lt 1 ]; then
                _COMPAT_MSG="RAM insuficiente para Satoshi Node (${GN_HW_RAM_GB}GB). Mínimo: 1GB."
                RC=2
            elif [ "$GN_HW_DISK_GB" -ge 400 ] && [ "$GN_HW_RAM_GB" -ge 2 ]; then
                _COMPAT_MODE="full"
                _COMPAT_MSG="Hardware compatível com Full Node Bitcoin."
            elif [ "$GN_HW_DISK_GB" -ge 10 ]; then
                _COMPAT_MODE="pruned"
                _COMPAT_MSG="Disco disponível: ${GN_HW_DISK_GB}GB (< 400GB necessários para Full Node)."
                _COMPAT_WARNINGS+=("Será instalado como Pruned Node (requer ~${SATOSHI_PRUNED_DISK_GB:-10}GB)")
                _COMPAT_WARNINGS+=("Pruned Node valida transações mas não armazena blockchain completo")
                RC=1
            else
                _COMPAT_MSG="Disco insuficiente (${GN_HW_DISK_GB}GB). Mínimo para Pruned Node: 10GB."
                RC=2
            fi
            ;;

        *)
            _COMPAT_MSG="Subprojeto '${PROJECT}' ainda não possui verificação de compatibilidade."
            RC=1
            ;;
    esac
    return $RC
}

# ══════════════════════════════════════════════════════════════════════════════
# DOWNLOAD E EXTRAÇÃO DO PROJETO
# ══════════════════════════════════════════════════════════════════════════════
download_project() {
    section "📥  Download do Projeto Ghost Node Nation"
    echo ""

    local TARBALL="/tmp/ghostnodes_beta.tar.gz"
    local EXTRACT_PARENT="/tmp"
    local EXTRACT_DIR="${EXTRACT_PARENT}/${GN_REPO_DIR_NAME}"

    # Verifica se já está instalado
    if [ -d "$GN_ROOT" ] && [ -f "${GN_ROOT}/halfin/lib/init.sh" ]; then
        step_ok "Projeto já instalado em: $GN_ROOT"
        if ! confirm "Baixar e reinstalar mesmo assim?" "n"; then
            return 0
        fi
    fi

    # Download
    if [ -f "$TARBALL" ] && confirm "Arquivo já existe. Usar cache?" "s"; then
        step_ok "Usando cache: $TARBALL"
    else
        step_info "Baixando de: $GN_REPO_URL"
        echo ""
        if command -v wget &>/dev/null; then
            wget -q --show-progress -O "$TARBALL" "$GN_REPO_URL" || {
                step_err "Falha no download via wget"
                return 1
            }
        elif command -v curl &>/dev/null; then
            curl -fSL --progress-bar -o "$TARBALL" "$GN_REPO_URL" || {
                step_err "Falha no download via curl"
                return 1
            }
        else
            step_err "wget ou curl não encontrado — instale um deles"
            return 1
        fi
        step_ok "Download concluído: $(du -sh "$TARBALL" | cut -f1)"
    fi

    echo ""

    # Extração
    step_info "Extraindo arquivos..."
    rm -rf "$EXTRACT_DIR"
    tar -xzf "$TARBALL" -C "$EXTRACT_PARENT" 2>/dev/null || {
        step_err "Falha na extração do tarball"
        return 1
    }

    # Renomeia ghostnodes-beta → nodenation
    if [ ! -d "$EXTRACT_DIR" ]; then
        # Tenta encontrar a pasta extraída
        EXTRACT_DIR=$(find "$EXTRACT_PARENT" -maxdepth 1 -type d -name "ghostnodes*" | head -1)
    fi

    if [ -z "$EXTRACT_DIR" ] || [ ! -d "$EXTRACT_DIR" ]; then
        step_err "Pasta extraída não encontrada em $EXTRACT_PARENT"
        return 1
    fi

    step_ok "Extraído: $EXTRACT_DIR"

    # Move para destino final
    step_info "Instalando em: $GN_ROOT"
    mkdir -p "$(dirname "$GN_ROOT")"
    rm -rf "$GN_ROOT"
    mv "$EXTRACT_DIR" "$GN_ROOT"

    # ── Sanitização completa dos arquivos extraídos ───────────────────────────
    sanitize_project "$GN_ROOT"

    # Cria diretórios necessários que podem não vir no tarball
    mkdir -p "${GN_ROOT}/var"
    mkdir -p "${GN_ROOT}/halfin/logs"
    mkdir -p "${GN_ROOT}/halfin/var"

    chown -R "${GN_USER}:${GN_USER}" "$GN_ROOT" 2>/dev/null || true

    # Migra arquivos temporários para GN_ROOT agora que ele existe
    mkdir -p "${GN_ROOT}/var"
    [ -f "/tmp/ghostnodes_hw.env" ] &&         mv "/tmp/ghostnodes_hw.env" "${GN_ROOT}/var/hardware.env" &&         GN_HW_COMPAT_FILE="${GN_ROOT}/var/hardware.env"
    [ -f "/tmp/ghostnodes_install.state" ] &&         mv "/tmp/ghostnodes_install.state" "${GN_ROOT}/var/install.state" &&         GN_STATE_FILE="${GN_ROOT}/var/install.state"

    # Carrega auto.sh para registro de pre_install
    _load_auto_sh

    step_ok "Projeto instalado em: $GN_ROOT"
    rm -f "$TARBALL"
    return 0
}

# ══════════════════════════════════════════════════════════════════════════════
# SANITIZE — corrige line endings, permissões e verifica integridade
# Chamado após qualquer extração de tarball
# Uso: sanitize_project "/caminho/do/projeto"
# ══════════════════════════════════════════════════════════════════════════════
sanitize_project() {
    local PROJECT_ROOT="$1"
    local FIXED_LF=0 FIXED_CHMOD=0 FIXED_EXEC=0 WARN_COUNT=0

    echo ""
    step_info "Sanitizando arquivos extraídos em: $PROJECT_ROOT"
    echo ""

    # ── 1. Corrige line endings CRLF → LF ────────────────────────────────────
    # Arquivos do GitHub/Windows chegam com \r\n que quebra o bash silenciosamente
    step_info "Verificando line endings (CRLF → LF)..."

    if command -v dos2unix &>/dev/null; then
        # dos2unix disponível — converte todos os scripts de uma vez
        find "$PROJECT_ROOT" -type f \( -name "*.sh" -o -name "*.env" -o -name "*.conf" \) \
            -print0 | xargs -0 dos2unix -q 2>/dev/null
        # Arquivos sem extensão que são scripts (shebang)
        find "$PROJECT_ROOT" -type f ! -name "*.*" -print0 | while IFS= read -r -d '' F; do
            head -c 2 "$F" 2>/dev/null | grep -q $'#!' && \
                dos2unix -q "$F" 2>/dev/null || true
        done
        FIXED_LF=1
        step_ok "dos2unix aplicado em todos os scripts e .env"
    else
        # Fallback sem dos2unix — usa sed para remover \r
        step_warn "dos2unix não encontrado — usando sed como fallback"
        local CRLF_COUNT=0
        find "$PROJECT_ROOT" -type f \( -name "*.sh" -o -name "*.env" \) | while read -r F; do
            if file "$F" 2>/dev/null | grep -q "CRLF\|with CRLF"; then
                sed -i 's/\r$//' "$F"
                CRLF_COUNT=$((CRLF_COUNT + 1))
            fi
        done
        # Arquivos sem extensão com shebang
        find "$PROJECT_ROOT" -type f ! -name "*.*" | while read -r F; do
            head -c 2 "$F" 2>/dev/null | grep -q $'#!' || continue
            if file "$F" 2>/dev/null | grep -q "CRLF\|with CRLF"; then
                sed -i 's/\r$//' "$F"
                CRLF_COUNT=$((CRLF_COUNT + 1))
            fi
        done
        [ "$CRLF_COUNT" -gt 0 ] \
            && step_ok "CRLF corrigido em $CRLF_COUNT arquivo(s)" \
            || step_ok "Nenhum arquivo com CRLF encontrado"
    fi

    # ── 2. chmod +x em todos os scripts .sh ──────────────────────────────────
    step_info "Aplicando chmod +x nos scripts .sh..."
    find "$PROJECT_ROOT" -type f -name "*.sh" | while read -r F; do
        if [ ! -x "$F" ]; then
            chmod +x "$F"
            FIXED_CHMOD=$((FIXED_CHMOD + 1))
        fi
    done
    step_ok "Permissão de execução garantida em todos os .sh"

    # ── 3. chmod +x em executáveis sem extensão (verifica shebang) ───────────
    step_info "Verificando scripts sem extensão (shebang)..."
    local EXEC_NAMES=("ghostnode" "nodenation" "satoshi" "halfin")
    for NAME in "${EXEC_NAMES[@]}"; do
        find "$PROJECT_ROOT" -type f -name "$NAME" | while read -r F; do
            chmod +x "$F"
            FIXED_EXEC=$((FIXED_EXEC + 1))
            printf "  ${BULLET} ${DIM}chmod +x %s${RESET}\n" "${F#${PROJECT_ROOT}/}"
        done
    done
    # Qualquer arquivo sem extensão com shebang válido
    find "$PROJECT_ROOT" -type f ! -name "*.*" | while read -r F; do
        head -c 2 "$F" 2>/dev/null | grep -q $'#!' || continue
        if [ ! -x "$F" ]; then
            chmod +x "$F"
            printf "  ${BULLET} ${DIM}chmod +x %s (shebang detectado)${RESET}\n" \
                   "${F#${PROJECT_ROOT}/}"
        fi
    done
    step_ok "Executáveis sem extensão verificados"

    # ── 4. Verifica integridade mínima ────────────────────────────────────────
    step_info "Verificando integridade mínima do projeto..."
    local REQUIRED_FILES=(
        "halfin/lib/init.sh"
        "halfin/lib/colors.sh"
        "halfin/lib/ui.sh"
        "halfin/lib/banner.sh"
        "halfin/lib/log.sh"
        "halfin/var/globals.env"
        "halfin/install.sh"
    )
    local MISSING=0
    for REL in "${REQUIRED_FILES[@]}"; do
        local FPATH="${PROJECT_ROOT}/${REL}"
        if [ ! -f "$FPATH" ]; then
            step_warn "Arquivo ausente: $REL"
            WARN_COUNT=$((WARN_COUNT + 1))
            MISSING=$((MISSING + 1))
        fi
    done
    [ "$MISSING" -eq 0 ] \
        && step_ok "Integridade OK — todos os arquivos essenciais presentes" \
        || step_warn "$MISSING arquivo(s) essencial(is) ausente(s) — o projeto pode estar incompleto"

    # ── 5. Relatório final ────────────────────────────────────────────────────
    echo ""
    printf "  ${DIM}┌─ Sanitização concluída ──────────────────────────────────┐${RESET}\n"
    printf "  ${DIM}│${RESET}  ${CHECK} Line endings  : %-38s${DIM}│${RESET}\n" "LF (Unix)"
    printf "  ${DIM}│${RESET}  ${CHECK} Permissões   : %-38s${DIM}│${RESET}\n" "chmod +x aplicado"
    if [ "$WARN_COUNT" -gt 0 ]; then
        printf "  ${DIM}│${RESET}  ${WARN}  Avisos       : %-38s${DIM}│${RESET}\n" "$WARN_COUNT arquivo(s) ausente(s)"
    else
        printf "  ${DIM}│${RESET}  ${CHECK} Integridade  : %-38s${DIM}│${RESET}\n" "OK"
    fi
    printf "  ${DIM}└──────────────────────────────────────────────────────────┘${RESET}\n"
}


# ══════════════════════════════════════════════════════════════════════════════
# AUTO.SH — carrega registro de pré-configurações
# ══════════════════════════════════════════════════════════════════════════════
_load_auto_sh() {
    local AUTO_FILE="${GN_ROOT}/var/auto.sh"
    if [ -f "$AUTO_FILE" ]; then
        _GN_AUTO_LOADED=""   # força reload
        source "$AUTO_FILE"
    fi
}

# ══════════════════════════════════════════════════════════════════════════════
# check_preinstall_exists — verifica se há pre_install para o hw/subprojeto
# Preenche: _GN_FOUND_SCRIPT, _GN_FOUND_DESC
# Retorna: 0=encontrou, 1=não encontrou
# ══════════════════════════════════════════════════════════════════════════════
check_preinstall_exists() {
    local PROJECT="$1"
    _GN_FOUND_SCRIPT=""; _GN_FOUND_DESC=""

    # Carrega auto.sh se ainda não foi feito
    if [ -z "${_GN_AUTO_LOADED:-}" ]; then
        _load_auto_sh
    fi

    # Se a função gn_find_preinstall foi carregada pelo auto.sh, usa ela
    if declare -f gn_find_preinstall &>/dev/null; then
        gn_find_preinstall "$PROJECT"
        return $?
    fi

    # Fallback: procura pre_install.sh direto na pasta do subprojeto
    local FALLBACK="${GN_ROOT}/${PROJECT}/pre_install.sh"
    if [ -f "$FALLBACK" ]; then
        _GN_FOUND_SCRIPT="$FALLBACK"
        _GN_FOUND_DESC="Configuração padrão para ${PROJECT}"
        return 0
    fi

    return 1
}

