# ── 5. Atualizar sistema ──────────────────────────────────────────────────────
_cfg_update() {
    banner_root
    section "🔄  Atualizar Sistema Hospedeiro"
    echo ""

    step_info "apt-get update..."
    set +e
    DEBIAN_FRONTEND=noninteractive apt-get update -q 2>&1         | while IFS= read -r L; do printf "  ${DIM}%s${RESET}
" "$L"; done

    local UPG
    UPG=$(apt list --upgradable 2>/dev/null | grep -c "/" || true)
    set -e

    if [ "$UPG" -eq 0 ]; then
        step_ok "Sistema já está atualizado"
        press_enter; return
    fi

    step_info "${UPG} pacote(s) disponível(is) para atualização"
    apt list --upgradable 2>/dev/null | grep "/"         | while IFS= read -r L; do printf "  ${DIM}%s${RESET}
" "$L"; done
    echo ""

    if confirm "Executar upgrade agora?"; then
        sep
        set +e
        DEBIAN_FRONTEND=noninteractive apt-get upgrade -y 2>&1             | while IFS= read -r L; do
                echo "$L" | grep -qiE "^E:|error|fatal"                     && printf "  ${RED}%s${RESET}
" "$L"                     || printf "  ${DIM}%s${RESET}
" "$L"
              done
        set -e
        sep
        step_ok "Upgrade concluído"
    fi
    press_enter
}

# ══════════════════════════════════════════════════════════════════════════════
# LANÇA SUBPROJETO — verifica hw, exibe avisos e executa install.sh
# ══════════════════════════════════════════════════════════════════════════════
launch_subproject() {
    local PROJECT="$1"
    local PROJECT_DIR="$2"
    local PROJECT_NAME="$3"

    banner_root
    section "🚀  $PROJECT_NAME — Verificação e Inicialização"
    echo ""

    # Hardware já detectado?
    if [ -z "${GN_HW_ARCH:-}" ]; then
        step_info "Hardware ainda não detectado — executando detecção..."
        detect_hardware
        echo ""
    fi

    # Exibe resumo de hardware
    printf "  ${BOLD}Hardware detectado:${RESET}\n"
    printf "  ${BULLET} Modelo      : ${BOLD}%s${RESET}\n" "${GN_HW_MODEL:-—}"
    printf "  ${BULLET} Arch        : ${BOLD}%s${RESET}\n" "${GN_HW_ARCH:-—}"
    printf "  ${BULLET} RAM         : ${BOLD}%s GB${RESET}\n" "${GN_HW_RAM_GB:-—}"
    printf "  ${BULLET} Disco (/)   : ${BOLD}%s GB${RESET}\n" "${GN_HW_DISK_GB:-—}"
    echo ""

    # ── Verifica pré-configuração automática (auto.sh) ────────────────────────
    _load_auto_sh
    if check_preinstall_exists "$PROJECT"; then
        echo ""
        printf "  ${GREEN}${BOLD}✔ Pré-configuração encontrada para este hardware:${RESET}\n"
        printf "  ${BULLET} ${BOLD}%s${RESET}\n" "$_GN_FOUND_DESC"
        printf "  ${DIM}  Script: %s${RESET}\n" "$_GN_FOUND_SCRIPT"
        echo ""
        printf "  ${BOLD}[1]${RESET}  Usar pré-configuração (recomendado)
"
        printf "  ${BOLD}[2]${RESET}  Configurar manualmente
"
        printf "  ${BOLD}[0]${RESET}  Voltar
"
        echo ""
        printf "  Opção: "
        read -r PRE_OPT
        case "$PRE_OPT" in
            1)
                # Verifica compatibilidade e executa pre_install
                local COMPAT_RC=0
                check_compat "$PROJECT" || COMPAT_RC=$?
                if [ "$COMPAT_RC" -eq 2 ]; then
                    step_err "$_COMPAT_MSG"
                    press_enter; return
                fi
                [ "$COMPAT_RC" -eq 1 ] && {
                    step_warn "$_COMPAT_MSG"
                    for W in "${_COMPAT_WARNINGS[@]:-}"; do
                        [ -n "$W" ] && printf "    ${WARN} ${YELLOW}%s${RESET}\n" "$W"
                    done
                    echo ""
                    confirm "Continuar mesmo assim?" || { press_enter; return; }
                }
                export GN_HW_ARCH GN_HW_MODEL GN_HW_RAM_GB GN_HW_DISK_GB GN_HW_CPU_CORES
                export GN_INSTALL_MODE="${_COMPAT_MODE:-standard}"
                export GN_ROOT GN_USER
                echo ""
                sep
                step_info "Executando pré-configuração: $_GN_FOUND_SCRIPT"
                sep
                bash "$_GN_FOUND_SCRIPT"
                return
                ;;
            2)
                menu_config_manual
                return
                ;;
            0|"") return ;;
        esac
    else
        # Sem pré-configuração — oferece menu manual
        step_warn "Nenhuma pré-configuração encontrada para: ${GN_HW_MODEL:-?} (${GN_HW_ARCH:-?})"
        echo ""
        printf "  ${BOLD}[1]${RESET}  Configurar manualmente
"
        printf "  ${BOLD}[2]${RESET}  Tentar instalar mesmo assim (sem pré-config)
"
        printf "  ${BOLD}[0]${RESET}  Voltar
"
        echo ""
        printf "  Opção: "
        read -r NO_PRE_OPT
        case "$NO_PRE_OPT" in
            1) menu_config_manual; return ;;
            2) : ;;  # continua o fluxo normal abaixo
            0|"") return ;;
        esac
    fi

    # Verifica compatibilidade
    local COMPAT_RC=0
    check_compat "$PROJECT" || COMPAT_RC=$?

    case $COMPAT_RC in
        0)
            step_ok "Hardware 100% compatível com $PROJECT_NAME"
            [ -n "${_COMPAT_MODE:-}" ] && step_info "Modo: ${_COMPAT_MODE}"
            ;;
        1)
            step_warn "$_COMPAT_MSG"
            for W in "${_COMPAT_WARNINGS[@]:-}"; do
                [ -n "$W" ] && printf "    ${WARN} ${YELLOW}%s${RESET}\n" "$W"
            done
            echo ""
            if ! confirm "Continuar mesmo com os avisos?"; then
                return
            fi
            ;;
        2)
            step_err "$_COMPAT_MSG"
            echo ""
            printf "  ${RED}Hardware incompatível — instalação bloqueada.${RESET}\n"
            press_enter
            return
            ;;
    esac

    echo ""

    # Verifica se o projeto está instalado
    local INSTALL_SCRIPT="${PROJECT_DIR}/install.sh"
    if [ ! -f "$INSTALL_SCRIPT" ]; then
        step_warn "Projeto não encontrado em: $PROJECT_DIR"
        if confirm "Baixar o projeto agora?"; then
            download_project || { press_enter; return; }
            # Re-verifica após download
            if [ ! -f "$INSTALL_SCRIPT" ]; then
                step_err "install.sh não encontrado após download: $INSTALL_SCRIPT"
                press_enter; return
            fi
        else
            press_enter; return
        fi
    fi

    # Exporta variáveis de hardware e modo para o install.sh do subprojeto
    export GN_HW_ARCH GN_HW_MODEL GN_HW_RAM_GB GN_HW_DISK_GB GN_HW_CPU_CORES
    export GN_INSTALL_MODE="${_COMPAT_MODE:-standard}"
    export GN_ROOT GN_USER

    echo ""
    sep
    step_info "Iniciando: $INSTALL_SCRIPT"
    sep
    echo ""
    sleep 1

    bash "$INSTALL_SCRIPT"
}

