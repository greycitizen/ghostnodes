# ── 1. Criar novo usuário ─────────────────────────────────────────────────────
_cfg_novo_usuario() {
    banner_root
    section "👤  Criar Novo Usuário"
    echo ""

    printf "  Nome do novo usuário: "
    read -r NEW_USER
    NEW_USER="${NEW_USER// /}"   # remove espaços

    if [ -z "$NEW_USER" ]; then
        step_err "Nome vazio — operação cancelada"; press_enter; return
    fi
    if ! [[ "$NEW_USER" =~ ^[a-z_][a-z0-9_-]*$ ]]; then
        step_err "Nome inválido. Use apenas letras minúsculas, números, _ ou -"
        press_enter; return
    fi
    if id "$NEW_USER" &>/dev/null; then
        step_warn "Usuário '${NEW_USER}' já existe"
        press_enter; return
    fi

    adduser --disabled-password --gecos "" "$NEW_USER" || {
        step_err "Falha ao criar usuário"; press_enter; return
    }

    echo ""
    printf "  Senha para '${NEW_USER}': "
    read -rs NEW_PASS; echo ""
    if [ -z "$NEW_PASS" ]; then
        step_warn "Senha vazia — usuário criado sem senha (bloqueado)"
    else
        echo "${NEW_USER}:${NEW_PASS}" | chpasswd
        step_ok "Senha definida"
    fi

    if confirm "Adicionar '${NEW_USER}' ao grupo sudo?"; then
        usermod -aG sudo "$NEW_USER"
        step_ok "Adicionado ao grupo sudo"
    fi

    step_ok "Usuário '${NEW_USER}' criado com sucesso"
    press_enter
}

# ── 2. Renomear interface de rede ─────────────────────────────────────────────
_cfg_alias_interface() {
    banner_root
    section "📡  Renomear Interface de Rede"
    echo ""

    # Verifica alias.sh do projeto
    local ALIAS_SCRIPT="${GN_ROOT}/halfin/tools/alias.sh"
    if [ -f "$ALIAS_SCRIPT" ]; then
        step_info "Usando tools/alias.sh do projeto..."
        bash "$ALIAS_SCRIPT"
        press_enter; return
    fi

    # Fallback inline
    step_info "Interfaces disponíveis:"
    echo ""
    iw dev 2>/dev/null | awk '$1=="Interface"{print "    • "$2}' ||         ip link show | awk -F': ' '/^[0-9]+:/{print "    • "$2}'
    echo ""

    printf "  Interface a renomear: "
    read -r IFACE_OLD
    if ! ip link show "$IFACE_OLD" &>/dev/null; then
        step_err "Interface '${IFACE_OLD}' não encontrada"; press_enter; return
    fi

    printf "  Novo nome: "
    read -r IFACE_NEW
    if ! [[ "$IFACE_NEW" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        step_err "Nome inválido"; press_enter; return
    fi

    local MAC
    MAC=$(cat "/sys/class/net/${IFACE_OLD}/address" 2>/dev/null)
    local RULE="/etc/udev/rules.d/70-rename-${IFACE_OLD}.rules"
    tee "$RULE" > /dev/null << UDEV
SUBSYSTEM=="net", ACTION=="add", ATTR{address}=="${MAC}", NAME="${IFACE_NEW}"
UDEV
    udevadm control --reload 2>/dev/null || true
    step_ok "Regra criada: ${IFACE_OLD} → ${IFACE_NEW} (após reboot)"
    press_enter
}

# ── 3. Configurar rede ────────────────────────────────────────────────────────
_cfg_rede() {
    banner_root
    section "🌐  Configuração de Rede"
    echo ""

    # Verifica se wifi_connect.sh está disponível
    local WIFI_SCRIPT="${GN_ROOT}/halfin/tools/wifi_connect.sh"
    if [ -f "$WIFI_SCRIPT" ]; then
        printf "  ${BOLD}${CYAN}[1]${RESET}  Conectar a rede Wi-Fi (wifi_connect.sh)
"
    fi
    printf "  ${BOLD}${CYAN}[2]${RESET}  Configurar IP fixo em interface
"
    printf "  ${BOLD}${CYAN}[3]${RESET}  Configurar DHCP em interface
"
    printf "  ${BOLD}[0]${RESET}  Voltar
"
    echo ""
    printf "  Opção: "
    read -r OPT

    case "$OPT" in
        1)
            [ -f "$WIFI_SCRIPT" ] && bash "$WIFI_SCRIPT" || step_err "wifi_connect.sh não encontrado"
            ;;
        2)
            echo ""
            printf "  Interface: "; read -r NIC
            printf "  IP (ex: 192.168.1.100/24): "; read -r IP_ADDR
            printf "  Gateway (ex: 192.168.1.1): "; read -r GW
            printf "  DNS (ex: 8.8.8.8): "; read -r DNS_IP
            ip addr add "$IP_ADDR" dev "$NIC" 2>/dev/null && step_ok "IP configurado"                 || step_err "Falha — verifique interface e IP"
            ip route add default via "$GW" 2>/dev/null || true
            echo "nameserver ${DNS_IP}" > /etc/resolv.conf
            step_ok "Rota e DNS configurados (temporário — use /etc/network/interfaces para persistir)"
            ;;
        3)
            echo ""
            printf "  Interface: "; read -r NIC
            dhclient "$NIC" 2>/dev/null && step_ok "DHCP configurado em ${NIC}"                 || step_err "Falha no dhclient"
            ;;
        0|"") return ;;
    esac
    press_enter
}

# ── 4. Alterar sources.list ───────────────────────────────────────────────────
_cfg_sourcelist() {
    banner_root
    section "📦  Alterar Sources.list  ${RED}⚠ Avançado${RESET}"
    echo ""
    printf "  ${RED}${BOLD}ATENÇÃO:${RESET} Alterar o sources.list incorretamente pode
"
    printf "  impedir atualizações e quebrar o sistema.

"

    printf "  ${BOLD}${CYAN}[1]${RESET}  Debian Bookworm oficial (recomendado)
"
    printf "  ${BOLD}${CYAN}[2]${RESET}  Debian Bullseye oficial
"
    printf "  ${BOLD}${CYAN}[3]${RESET}  Editar manualmente (nano)
"
    printf "  ${BOLD}[0]${RESET}  Voltar sem alterar
"
    echo ""
    printf "  Opção: "
    read -r OPT

    cp /etc/apt/sources.list "/etc/apt/sources.list.bak.$(date +%Y%m%d%H%M%S)" 2>/dev/null || true

    case "$OPT" in
        1)
            tee /etc/apt/sources.list > /dev/null << 'SRC'
deb http://deb.debian.org/debian bookworm main contrib non-free non-free-firmware
deb http://deb.debian.org/debian bookworm-updates main contrib non-free non-free-firmware
deb http://deb.debian.org/debian bookworm-backports main contrib non-free non-free-firmware
deb http://security.debian.org/debian-security bookworm-security main contrib non-free non-free-firmware
SRC
            step_ok "sources.list atualizado para Debian Bookworm"
            ;;
        2)
            tee /etc/apt/sources.list > /dev/null << 'SRC'
deb http://deb.debian.org/debian bullseye main contrib non-free
deb http://deb.debian.org/debian bullseye-updates main contrib non-free
deb http://security.debian.org/debian-security bullseye-security main contrib non-free
SRC
