        printf "  ${BOLD}${CYAN}[6]${RESET}  ${BOLD}Nash Node${RESET}       ${DIM}…  Em breve${RESET}\n"
        printf "  ${BOLD}${CYAN}[7]${RESET}  ${BOLD}Craig Node${RESET}      ${DIM}…  Em breve${RESET}\n"
        echo ""
        sep_thin
        echo ""
        printf "  ${BOLD}[d]${RESET}  Baixar / Atualizar projeto\n"
        printf "  ${BOLD}[h]${RESET}  Detectar Hardware\n"
        printf "  ${BOLD}[c]${RESET}  Configuração Manual do Sistema\n"
        printf "  ${BOLD}[?]${RESET}  Ajuda\n"
        printf "  ${BOLD}[q]${RESET}  Sair\n"
        sep
        echo ""
        printf "  ${BOLD}Opção:${RESET} "
        read -r OPT

        case "$OPT" in
            1) launch_subproject "halfin"  "${GN_ROOT}/halfin"  "Halfin Node"  ;;
            2) menu_satoshi ;;
            3) menu_coming_soon "Nick Node" ;;
            4) menu_coming_soon "Adam Node" ;;
            5) menu_coming_soon "Fiatjaf Node" ;;
            6) menu_coming_soon "Nash Node" ;;
            7) menu_coming_soon "Craig Node" ;;
            d|D) download_project; press_enter ;;
            h|H) detect_hardware; press_enter ;;
            c|C) menu_config_manual ;;
            "?") show_help ;;
            q|Q|0) printf "\n  ${DIM}Saindo...${RESET}\n\n"; exit 0 ;;
            "") : ;;
            *) step_warn "Opção inválida"; sleep 1 ;;
        esac
    done
}

# ══════════════════════════════════════════════════════════════════════════════
# PONTO DE ENTRADA
# ══════════════════════════════════════════════════════════════════════════════
if [ "$EUID" -ne 0 ]; then
    printf "\n  ${RED}[ERRO]${RESET} Execute como root: ${BOLD}sudo bash nodenation${RESET}\n\n"
    exit 1
fi

# Cria apenas /tmp staging — GN_ROOT só é criado após o usuário pleb existir
mkdir -p "$GN_TMP_DIR" 2>/dev/null || true

# Tenta carregar a lib se o projeto já estiver instalado
if [ -f "${LIB_DIR}/init.sh" ]; then
    source "${LIB_DIR}/init.sh" 2>/dev/null || true
fi

# Carrega hardware salvo (se existir)
[ -f "$GN_HW_COMPAT_FILE" ] && source "$GN_HW_COMPAT_FILE" 2>/dev/null || true

case "${1:-}" in
    --help|-h)         show_help ;;
    --download-only)   detect_hardware; download_project; exit 0 ;;
    --detect-hw)       detect_hardware; exit 0 ;;
    *)
        # Detecta hw se ainda não foi feito
        [ -z "${GN_HW_ARCH:-}" ] && detect_hardware
        menu_principal
        ;;
esac
