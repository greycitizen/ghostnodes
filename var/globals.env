# ══════════════════════════════════════════════════════════════════════════════
# GLOBAIS DO GHOST NODE NATION
# ══════════════════════════════════════════════════════════════════════════════

# Definições principais do usuário da máquina
GHOST_USER="pleb"
GHOST_HOME="/home/${GHOST_USER}"

# Repositório Central
NODENATION_DIR="${GHOST_HOME}/nodenation"

# Diretórios dos Projetos (Subnodes)
HALFIN_DIR="${GHOST_HOME}/halfin"
SATOSHI_DIR="${GHOST_HOME}/satoshi"
NICK_DIR="${GHOST_HOME}/nick"
NASH_DIR="${GHOST_HOME}/nash"
ADAM_DIR="${GHOST_HOME}/adam"
FIATJAF_DIR="${GHOST_HOME}/fiatjaf"
CRAIG_DIR="${GHOST_HOME}/craig"

# Pastas Comuns (Referências Cruzadas)
LOGS_DIR="${NODENATION_DIR}/logs"
BACKUPS_DIR="${NODENATION_DIR}/backups"
VAR_DIR="${NODENATION_DIR}/var"
LIB_DIR="${NODENATION_DIR}/lib"

# Constante de Bitcoin Core (se instalado pelo sistema ao invés do docker)
BTC_DATA_DIR="${GHOST_HOME}/.bitcoin"

# Flags do sistema
ENV_TYPE="production" # production | development
ARCH="$(uname -m)"
OS_NAME="$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || echo "desconhecido")"
